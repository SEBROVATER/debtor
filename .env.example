# debtor environment configuration
# Copy this file to .env and fill in your values.
# All variables are optional except APP_ADMIN_PASSWORD_HASH (required for login).
# System environment variables take precedence over .env values.

# SQLite database connection URL
# APP_DATABASE_URL=sqlite://debtor.db?mode=rwc

# Name of the HTTP session cookie
# APP_SESSION_COOKIE_NAME=debtor_session

# Username for the single admin account
# APP_ADMIN_USERNAME=owner

# Argon2-hashed password for the admin account (REQUIRED for login)
# Generate with: argon2 <salt> -e
# APP_ADMIN_PASSWORD_HASH=

# Whether the session cookie requires HTTPS (true/false)
# APP_SESSION_COOKIE_SECURE=false

# Base URL for the exchange rate API
# APP_EXCHANGE_BASE_URL=https://api.frankfurter.app

# SQLx offline mode — allows `cargo build` without a live database.
# The .sqlx/ directory (generated by `cargo sqlx prepare`) must be committed.
SQLX_OFFLINE=true

# Used only when regenerating .sqlx/ metadata:
#   DATABASE_URL=sqlite://debtor.db?mode=rwc cargo sqlx prepare
# DATABASE_URL=sqlite://debtor.db?mode=rwc
